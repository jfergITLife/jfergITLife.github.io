---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  });
---

<Base title="JFergITLife — notes.log" description="Welcome to my brain. Write-ups on new tech, old tech, opinions, deep thoughts, and the occasional rant. A thinking place that happens to be public.">
  <main class="terminal">
    <div class="prompt-line">
      <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~</span><span class="punct">$</span>
      <span class="cmd">tail -f notes.log</span>
    </div>
    <h1 class="ascii-title" aria-label="JFergITLife">
<pre>{`
     _ _____                ___ _____ _      _  __     
    | |  ___|__ _ __ __ _  |_ _|_   _| |    (_)/ _| ___
 _  | | |_ / _ \\ '__/ _\` |  | |  | | | |    | | |_ / _ \\
| |_| |  _|  __/ | | (_| |  | |  | | | |___ | |  _|  __/
 \\___/|_|  \\___|_|  \\__, | |___| |_| |_____||_|_|  \\___|
                    |___/                               
`}</pre>
    </h1>
    <p class="tagline">
      <span class="comment">//</span> freedom to write is freedom to think. this is where i do both.
    </p>
    <section class="callout">
      <p>
        welcome to my brain. you'll find write-ups on new tech trends, old tech trends,
        opinions, deep thoughts, and the occasional rant. this is my thinking place and
        it is public.
      </p>
      <p>
        marcus aurelius wrote meditations for himself. it was never meant to be published.
        look where it ended up.
      </p>
    </section>

    <section class="ls-block" aria-label="Recent posts">
      <div class="prompt-line small">
        <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~/posts</span><span class="punct">$</span>
        <span class="cmd">ls -lt</span>
      </div>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p class="ls-output">total 0</p>
          <p class="ls-output">-- no posts yet. first one drops soon. --</p>
        </div>
      ) : (
        <ul class="post-list">
          <li class="ls-output total">total {posts.length}</li>
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.slug}`} class="post-link">
                <span class="ls-perms">-rw-r--r--</span>
                <span class="ls-date">{formatDate(post.data.pubDate)}</span>
                <span class="ls-title">{post.data.title}</span>
              </a>
              <p class="post-desc">
                <span class="comment">//</span> {post.data.description}
              </p>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="subscribe-block">
      <div class="prompt-line small">
        <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~</span><span class="punct">$</span>
        <span class="cmd">subscribe --email</span>
      </div>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/JfergITLife"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.com/JfergITLife', 'popupwindow')"
        class="subscribe-form"
      >
        <input type="email" name="email" id="bd-email" placeholder="you@domain.com" required />
        <button type="submit">notify me</button>
      </form>
      <p class="subscribe-note">
        <span class="comment">//</span> no spam. unsubscribe anytime. ~1 email per post.
      </p>
    </section>

    <footer class="footer-nav">
      <a href="/">← back to portfolio</a>
      <a href="https://www.linkedin.com/in/jfergitlife/" target="_blank" rel="noopener">linkedin →</a>
      <a href="https://github.com/jfergITLife" target="_blank" rel="noopener">github →</a>
    </footer>
  </main>
</Base>

<style>
  .terminal {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
    color: #e2e8f0;
  }

  .prompt-line {
    margin-bottom: 1.5rem;
    color: #94a3b8;
  }

  .prompt-line.small {
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .prompt-line .user { color: #4ade80; }
  .prompt-line .path { color: #60a5fa; }
  .prompt-line .punct { color: #94a3b8; }
  .prompt-line .cmd { color: #e2e8f0; }

  .ascii-title {
    margin: 0 0 1rem 0;
    overflow-x: hidden;
  }

  .ascii-title pre {
    font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
    font-size: clamp(0.5rem, 2.2vw, 1rem);
    line-height: 1.1;
    margin: 0;
    background: linear-gradient(180deg, #a855f7 0%, #ec4899 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    white-space: pre;
  }

  .tagline {
    font-size: 0.95rem;
    color: #fbbf24;
    margin: 0 0 2rem 0;
  }

  .tagline .comment {
    color: #fbbf24;
    margin-right: 0.5rem;
  }

  .callout {
    border-left: 3px solid #fbbf24;
    padding: 0.75rem 1rem;
    margin: 0 0 2.5rem 0;
    color: #cbd5e1;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .callout p {
    margin: 0 0 0.875rem 0;
  }

  .callout p:last-child {
    margin-bottom: 0;
  }

  .ls-block {
    margin: 0 0 2.5rem 0;
  }

  .ls-output {
    font-size: 0.875rem;
    color: #94a3b8;
    margin: 0 0 0.25rem 0;
  }

  .empty-state .ls-output {
    color: #64748b;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list .total {
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .post-item {
    margin-bottom: 1.25rem;
  }

  .post-link {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 1rem;
    align-items: baseline;
    text-decoration: none;
    font-size: 0.875rem;
    padding: 0.25rem 0;
  }

  .post-link:hover .ls-title {
    color: #93c5fd;
    text-decoration: underline;
  }

  .ls-perms {
    color: #64748b;
    font-size: 0.8125rem;
  }

  .ls-date {
    color: #94a3b8;
    font-size: 0.8125rem;
  }

  .ls-title {
    color: #60a5fa;
    font-weight: 500;
  }

  .post-desc {
    font-size: 0.8125rem;
    color: #94a3b8;
    margin: 0.25rem 0 0 0;
    padding-left: 0;
  }

  .post-desc .comment {
    color: #fbbf24;
    margin-right: 0.5rem;
  }

  .subscribe-block {
    margin: 0 0 2.5rem 0;
    padding: 1.25rem;
    background: #1e293b;
    border-radius: 6px;
  }

  .subscribe-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .subscribe-form input[type="email"] {
    flex: 1;
    background: #0f172a;
    border: 1px solid #334155;
    color: #e2e8f0;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.875rem;
  }

  .subscribe-form input[type="email"]::placeholder {
    color: #64748b;
  }

  .subscribe-form input[type="email"]:focus {
    outline: none;
    border-color: #fbbf24;
  }

  .subscribe-form button {
    background: #fbbf24;
    color: #0f172a;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }

  .subscribe-form button:hover {
    background: #f59e0b;
  }

  .subscribe-note {
    font-size: 0.8125rem;
    color: #94a3b8;
    margin: 0;
  }

  .subscribe-note .comment {
    color: #fbbf24;
    margin-right: 0.5rem;
  }

  .footer-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #334155;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
  }

  .footer-nav a {
    color: #60a5fa;
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: #93c5fd;
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .post-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>