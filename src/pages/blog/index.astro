---
import Base from '../../layouts/Base.astro';
---

<Base title="JFergITLife — notes.log" description="A blog by Jacob Ferguson on cloud security, GRC engineering, tech history, and whatever else is on my mind.">
  <main class="terminal">
    <div class="prompt-line">
      <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~</span><span class="punct">$</span>
      <span class="cmd">tail -f notes.log</span>
    </div>

    <h1 class="ascii-title" aria-label="JFergITLife">
<pre>{`
     _ _____                ___ _____ _      _  __     
    | |  ___|__ _ __ __ _  |_ _|_   _| |    (_)/ _| ___
 _  | | |_ / _ \\ '__/ _\` |  | |  | | | |    | | |_ / _ \\
| |_| |  _|  __/ | | (_| |  | |  | | | |___ | |  _|  __/
 \\___/|_|  \\___|_|  \\__, | |___| |_| |_____||_|_|  \\___|
                    |___/                               
`}</pre>
    </h1>

    <p class="tagline">
      <span class="comment">//</span> freedom to write is freedom to think. this is where i do both.
    </p>

    <section class="callout">
      <p>
        welcome to my brain. you'll find write-ups on new tech trends, old tech trends, opinions, deep thoughts, and the occasional rant. this is my thinking place and it is public. 
      </p>
      <p>
        marcus aurelius wrote meditations for himself. it was never meant to be published. look where it ended up. 
      </p>
    </section>

    <section class="ls-block" aria-label="Recent posts">
      <div class="prompt-line small">
        <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~/posts</span><span class="punct">$</span>
        <span class="cmd">ls -lt</span>
      </div>
      <pre class="ls-output">{`total 0
-- no posts yet. first one drops soon. --`}</pre>
    </section>

    <section class="subscribe" aria-label="Subscribe">
      <div class="prompt-line small">
        <span class="user">jacob@blog</span><span class="punct">:</span><span class="path">~</span><span class="punct">$</span>
        <span class="cmd">subscribe --email</span>
      </div>

      <form
        action="https://buttondown.com/api/emails/embed-subscribe/JfergITLife"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.com/JfergITLife', 'popupwindow')"
        class="sub-form"
      >
        <label for="bd-email" class="sr-only">Email address</label>
        <input
          id="bd-email"
          type="email"
          name="email"
          placeholder="you@domain.com"
          autocomplete="email"
          required
        />
        <button type="submit">notify me</button>
      </form>

      <p class="fineprint">
        <span class="comment">//</span> no spam. unsubscribe anytime. ~1 email per post.
      </p>
    </section>

    <hr class="divider" />

    <nav class="footer-nav" aria-label="Footer">
      <a href="/">← back to portfolio</a>
      <a href="https://www.linkedin.com/in/itlife" target="_blank" rel="noopener noreferrer">linkedin →</a>
      <a href="https://github.com/jfergITLife" target="_blank" rel="noopener noreferrer">github →</a>
    </nav>

    <div class="cursor-line" aria-hidden="true">
      <span class="block-cursor"></span>
      <span class="muted">waiting for input...</span>
    </div>
  </main>
</Base>

<style>
  .terminal {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    color: var(--fg, #e6e6e6);
    line-height: 1.6;
  }

  .prompt-line {
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .prompt-line.small {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .user { color: var(--accent-green, #7ee787); }
  .path { color: var(--accent-blue, #79c0ff); }
  .punct { color: var(--muted, #8b949e); }
  .cmd { color: var(--fg, #e6e6e6); }
  .comment { color: var(--muted, #8b949e); }

  .ascii-title {
    margin: 0.5rem 0 1.5rem;
    font-size: 0.7rem;
    line-height: 1.1;
  }

  .ascii-title pre {
    margin: 0;
    background: linear-gradient(180deg, #a855f7 0%, #ec4899 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-family: inherit;
    font-weight: 700;
    font-size: clamp(0.5rem, 2.2vw, 1rem);
    overflow-x: auto;
    white-space: pre;
  }

  .tagline {
    color: var(--accent-gold, #c9a84c);
    margin: 0 0 2rem;
    font-size: 1rem;
  }

  .callout {
    border-left: 2px solid var(--accent-gold, #c9a84c);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 0 0 2.5rem;
    color: var(--fg, #e6e6e6);
  }

  .callout p { margin: 0 0 0.85rem; }
  .callout p:last-child { margin-bottom: 0; }

  .ls-block { margin: 0 0 2.5rem; }

  .ls-output {
    margin: 0;
    padding: 0.5rem 0 0;
    color: var(--muted, #8b949e);
    font-family: inherit;
    font-size: 0.95rem;
  }

  .subscribe {
    border: 1px solid var(--border, #30363d);
    border-radius: 6px;
    padding: 1.25rem 1.25rem 1rem;
    margin: 0 0 2.5rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .sub-form {
    display: flex;
    gap: 0.5rem;
    margin: 0.5rem 0 0.75rem;
  }

  .sub-form input[type="email"] {
    flex: 1;
    background: var(--bg-input, #0d1117);
    border: 1px solid var(--border, #30363d);
    color: var(--fg, #e6e6e6);
    padding: 0.6rem 0.8rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
  }

  .sub-form input[type="email"]:focus {
    outline: none;
    border-color: var(--accent-gold, #c9a84c);
  }

  .sub-form button {
    background: var(--accent-gold, #c9a84c);
    color: #1a1a1a;
    border: none;
    padding: 0 1.1rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease;
  }

  .sub-form button:hover { background: #d6b65c; }
  .sub-form button:active { transform: translateY(1px); }

  .fineprint {
    margin: 0;
    color: var(--muted, #8b949e);
    font-size: 0.85rem;
  }

  .divider {
    border: 0;
    border-top: 1px solid var(--border, #30363d);
    margin: 2rem 0;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .footer-nav a {
    color: var(--accent-blue, #79c0ff);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    font-size: 0.95rem;
  }

  .footer-nav a:hover {
    border-bottom-color: var(--accent-blue, #79c0ff);
  }

  .cursor-line {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--muted, #8b949e);
    font-size: 0.9rem;
  }

  .block-cursor {
    display: inline-block;
    width: 0.55rem;
    height: 1.05rem;
    background: var(--accent-gold, #c9a84c);
    animation: blink 1.05s steps(2, start) infinite;
  }

  .muted { color: var(--muted, #8b949e); }

  @keyframes blink {
    to { visibility: hidden; }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 560px) {
    .terminal { padding: 2.5rem 1rem 4rem; }
    .ascii-title { font-size: 0.55rem; }
    .sub-form { flex-direction: column; }
    .sub-form button { padding: 0.7rem 1rem; }
  }
</style>
</Base>
