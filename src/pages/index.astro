---
import Base from '../layouts/Base.astro';

const projects = [
  {
    id: 'terraform',
    number: '01',
    title: 'Terraform GCP Lab',
    description: 'Least-privilege bucket deploy with auditable apply trail.',
    stack: 'terraform · gcp · iam',
    videoId: 'oKp5Nt4Jdto',
    videoLabel: 'terraform_gcp_lab.mp4',
    repoUrl: 'https://github.com/jfergITLife/grc-engineering-lab',
  },
  {
    id: 's3',
    number: '02',
    title: 'S3 Public Access Auditor',
    description: 'Scans AWS buckets for public exposure. SHA-256 evidence chain.',
    stack: 'python · boto3 · aws',
    videoId: 'TqSF1EqRdoI',
    videoLabel: 's3_public_access_auditor.mp4',
    repoUrl: 'https://github.com/jfergITLife/grc-engineering-lab',
  },
  {
    id: 'aws',
    number: '03',
    title: 'AWS Automated Access Review',
    description: 'Multi-framework IAM audit with mapped control evidence.',
    stack: 'python · aws · cis · soc 2',
    videoId: 'aCdDfTN2XNo',
    videoLabel: 'aws_automated_access_review.mp4',
    repoUrl: 'https://github.com/jfergITLife/grc-aws-access-review',
  },
];

const certs = [
  'Security+',
  'Network+',
  'A+',
  'SC-900',
  'AZ-900',
  'MS-900',
  'BTL1',
  'ITIL',
];
---
<Base title="Jacob Ferguson — GRC Engineer">
  <main class="container">

    <div class="prompt">
      <span class="user">jacob@portfolio</span>:<span class="host">~</span>$ <span class="cmd">whoami</span>
    </div>

    <section class="hero">
      <div class="avatar">
        <span class="placeholder">[ headshot ]</span>
      </div>
      <h1>Jacob Ferguson</h1>
      <p class="tagline">grc engineer. navy veteran. building provable security.</p>
      <p class="subtag">// rice mba '28 · houston, tx</p>
    </section>

    <section>
      <div class="prompt">
        <span class="user">jacob@portfolio</span>:<span class="host">~</span>$ <span class="cmd">cat about.md</span>
      </div>
      <div class="about">
        <p>
          Seven years in the Navy taught me that processes only matter if they hold up under pressure. I bring the same standard to security and compliance work.
        </p>
        <p>
          I build tools that produce evidence machines can verify, not screenshots people have to trust. Currently focused on cloud security automation, AI governance, and turning compliance theater into engineered controls.
        </p>
      </div>
    </section>

    <section>
      <div class="prompt">
        <span class="user">jacob@portfolio</span>:<span class="host">~</span>$ <span class="cmd">ls projects/</span>
      </div>
      <div class="grid">
        {projects.map((p) => (
          <article class="card">
            <div class="card-num">// {p.number}</div>
            <h3>{p.title}</h3>
            <p class="card-desc">{p.description}</p>
            <div class="card-stack">{p.stack}</div>
            <div class="card-actions">
              <a
                class="gold watch"
                data-video-id={p.videoId}
                data-video-label={p.videoLabel}
                href="#"
              >▶ walkthrough</a>
              <a href={p.repoUrl} target="_blank" rel="noopener">github →</a>
            </div>
          </article>
        ))}
      </div>

      <div id="video-panel" class="video-panel" hidden>
        <div class="video-header">
          <span id="video-label" class="video-title">▶ playing</span>
          <button id="video-close" class="video-close" type="button">[ x close ]</button>
        </div>
        <div class="video-frame-wrap">
          <iframe
            id="video-frame"
            src=""
            title="Project walkthrough"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <section>
      <div class="prompt">
        <span class="user">jacob@portfolio</span>:<span class="host">~</span>$ <span class="cmd">cat certifications.txt</span>
      </div>
      <div class="cert-row">
        {certs.map((c) => <span class="cert">{c}</span>)}
      </div>
    </section>

    <footer>
      <div class="prompt">
        <span class="user">jacob@portfolio</span>:<span class="host">~</span>$ <span class="cmd">connect</span>
      </div>
      <div class="links">
        <a href="https://linkedin.com/in/itlife" target="_blank" rel="noopener">linkedin →</a>
        <a href="https://github.com/jfergITLife" target="_blank" rel="noopener">github →</a>
        <a href="/resume.pdf" target="_blank">resume.pdf →</a>
        <a href="/blog" class="gold">blog →</a>
      </div>
      <div class="end">
        <span style="color: var(--gold);">▊</span> end of file.
      </div>
    </footer>

  </main>

  <style>
    main {
      padding-top: 1rem;
    }

    section {
      margin-bottom: 4rem;
    }

    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-bottom: 4rem;
    }

    .avatar {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: #2a2d31;
      border: 2px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }

    .avatar .placeholder {
      color: var(--text-dim);
      font-size: 11px;
    }

    h1 {
      font-size: 28px;
      color: #e8e8e8;
      margin-bottom: 0.75rem;
      letter-spacing: -0.5px;
    }

    .tagline {
      font-size: 16px;
      color: var(--gold);
      margin-bottom: 0.5rem;
    }

    .subtag {
      font-size: 13px;
      color: var(--text-dim);
    }

    .about {
      border-left: 2px solid var(--gold);
      padding-left: 1.25rem;
    }

    .about p {
      font-size: 15px;
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    .about p:last-child {
      margin-bottom: 0;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }

    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
    }

    .card-num {
      font-size: 11px;
      color: var(--gold);
      margin-bottom: 8px;
    }

    .card h3 {
      font-size: 15px;
      color: #e8e8e8;
      margin-bottom: 0.5rem;
    }

    .card-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 12px;
    }

    .card-stack {
      font-size: 11px;
      color: var(--blue);
      margin-bottom: 12px;
    }

    .card-actions {
      display: flex;
      gap: 12px;
      font-size: 11px;
      margin-top: auto;
    }

    .video-panel {
      margin-top: 1.5rem;
      background: var(--bg-card);
      border: 1px solid var(--gold);
      border-radius: 12px;
      padding: 1rem 1.25rem;
    }

    .video-panel[hidden] {
      display: none;
    }

    .video-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .video-title {
      font-size: 12px;
      color: var(--gold);
    }

    .video-close {
      background: none;
      border: none;
      color: var(--text-dim);
      font-size: 11px;
      font-family: var(--font-mono);
      cursor: pointer;
      padding: 0;
    }

    .video-close:hover {
      color: var(--text);
    }

    .video-frame-wrap {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      background: #0a0c0e;
      border-radius: 8px;
      overflow: hidden;
    }

    .video-frame-wrap iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .cert-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .cert {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      font-size: 12px;
      color: var(--text);
    }

    footer {
      border-top: 1px solid var(--border);
      padding-top: 2rem;
    }

    .links {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .links a {
      font-size: 14px;
    }

    .end {
      margin-top: 2rem;
      font-size: 11px;
      color: var(--text-dim);
    }
  </style>

  <script>
    const panel = document.getElementById('video-panel') as HTMLDivElement;
    const frame = document.getElementById('video-frame') as HTMLIFrameElement;
    const label = document.getElementById('video-label') as HTMLSpanElement;
    const closeBtn = document.getElementById('video-close') as HTMLButtonElement;

    document.querySelectorAll<HTMLAnchorElement>('a.watch').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.videoId;
        const name = link.dataset.videoLabel;
        if (!id || !name) return;
        frame.src = `https://www.youtube.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
        label.textContent = `▶ playing: ${name}`;
        panel.hidden = false;
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });

    closeBtn.addEventListener('click', () => {
      frame.src = '';
      panel.hidden = true;
    });
  </script>
</Base>
