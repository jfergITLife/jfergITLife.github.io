---
import Base from '../layouts/Base.astro';

const proof = [
  {
    title: 'Target Roles',
    text: 'Network technician, junior network engineer, systems administrator, infrastructure support.',
  },
  {
    title: 'Core Strengths',
    text: 'Subnetting, VLANs, routing basics, Linux, Windows, IAM, cloud labs, scripting, troubleshooting.',
  },
  {
    title: 'Certifications',
    text: 'Security+ · Network+ · A+ · SC-900 · AZ-900 · MS-900 · BTL1 · ITIL',
  },
];

const projects = [
  {
    title: 'Terraform GCP Infrastructure Lab',
    text: 'Repeatable cloud deployment with IAM, storage configuration, and rebuildable documentation.',
    stack: 'Terraform · GCP · IAM',
  },
  {
    title: 'Python Infrastructure Exposure Scanner',
    text: 'Admin utility for enumerating AWS storage exposure and turning findings into remediation steps.',
    stack: 'Python · boto3 · AWS',
  },
  {
    title: 'Automated Access Review Toolkit',
    text: 'Collects IAM data, normalizes account access, and produces concise review output.',
    stack: 'Python · AWS IAM · CSV',
  },
];
---

<Base
  title="Jacob Ferguson | Network Engineering & Systems Administration"
  description="Jacob Ferguson portfolio for network engineering, systems administration, and infrastructure support roles."
>
  <div class="network-bg" aria-hidden="true">
    <span class="device router">RTR</span>
    <span class="device switch">SW1</span>
    <span class="device server">SRV</span>
    <span class="device switch alt">SW2</span>
    <span class="cable cable-one"></span>
    <span class="cable cable-two"></span>
    <span class="cable cable-three"></span>
    <span class="port port-one"></span>
    <span class="port port-two"></span>
    <span class="port port-three"></span>
  </div>

  <main class="page">
    <header class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Houston, TX · Navy veteran</p>
        <h1>Jacob Ferguson</h1>
        <p class="role">Network Engineering · Systems Administration · Infrastructure Support</p>
        <p class="summary">
          Hands-on infrastructure practitioner focused on routed networks, Windows and Linux systems,
          cloud foundations, automation, and clear operational documentation.
        </p>
        <div class="actions" aria-label="Profile links">
          <a class="button primary" href="/resume.pdf" target="_blank">Resume</a>
          <a class="button" href="https://www.linkedin.com/in/itlife" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
      <img class="portrait" src="/images/headshot.jpg" alt="Jacob Ferguson" />
    </header>

    <section class="section quick-read" aria-labelledby="quick-read-title">
      <h2 id="quick-read-title">30-second read</h2>
      <div class="proof-grid">
        {proof.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="projects-title">
      <div class="section-heading">
        <h2 id="projects-title">Selected Projects</h2>
        <p>Short, practical labs that show infrastructure thinking and admin automation.</p>
      </div>

      <div class="project-list">
        {projects.map((project) => (
          <article class="project">
            <div>
              <h3>{project.title}</h3>
              <p>{project.text}</p>
            </div>
            <span>{project.stack}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section focus" aria-labelledby="focus-title">
      <h2 id="focus-title">Technical Focus</h2>
      <ul>
        <li>Network fundamentals: TCP/IP, DNS, DHCP, subnetting, VLANs, routing, VPN concepts.</li>
        <li>Systems administration: Windows, Linux, endpoint baselines, patching, backups, logs.</li>
        <li>Automation: Python, PowerShell, Bash, Terraform, structured checks, readable runbooks.</li>
      </ul>
    </section>

    <footer class="footer">
      <p>Open to network engineering, systems administration, and infrastructure support roles.</p>
      <a href="https://www.linkedin.com/in/itlife" target="_blank" rel="noopener">Connect on LinkedIn</a>
    </footer>
  </main>

  <style>
    :global(body) {
      background:
        linear-gradient(rgba(142, 240, 199, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(142, 240, 199, 0.045) 1px, transparent 1px),
        radial-gradient(circle at 82% 12%, rgba(64, 211, 154, 0.16), transparent 24rem),
        radial-gradient(circle at 8% 28%, rgba(80, 160, 255, 0.1), transparent 20rem),
        var(--bg);
      background-size: 42px 42px, 42px 42px, auto, auto;
    }

    .network-bg {
      position: fixed;
      inset: 0;
      z-index: -1;
      overflow: hidden;
      pointer-events: none;
    }

    .network-bg::before {
      position: absolute;
      top: 90px;
      right: max(18px, calc((100vw - 1180px) / 2));
      width: min(520px, 42vw);
      height: 380px;
      content: "";
      border: 1px solid rgba(142, 240, 199, 0.1);
      border-radius: 8px;
      background:
        linear-gradient(90deg, transparent 23px, rgba(142, 240, 199, 0.08) 24px, transparent 25px),
        linear-gradient(transparent 23px, rgba(142, 240, 199, 0.08) 24px, transparent 25px);
      background-size: 48px 48px;
      opacity: 0.72;
    }

    .device,
    .cable,
    .port {
      position: absolute;
      opacity: 0.3;
    }

    .device {
      display: grid;
      width: 86px;
      height: 38px;
      place-items: center;
      border: 1px solid rgba(142, 240, 199, 0.28);
      border-radius: 6px;
      background: rgba(9, 20, 22, 0.72);
      color: var(--accent-soft);
      font-size: 0.72rem;
      font-weight: 800;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
    }

    .device::after {
      position: absolute;
      right: 8px;
      bottom: 7px;
      display: block;
      width: 24px;
      height: 4px;
      content: "";
      background:
        linear-gradient(90deg, rgba(64, 211, 154, 0.76) 4px, transparent 4px 8px) repeat-x;
      background-size: 8px 4px;
    }

    .router {
      top: 122px;
      right: 340px;
    }

    .switch {
      top: 236px;
      right: 180px;
    }

    .server {
      top: 360px;
      right: 380px;
    }

    .switch.alt {
      top: 510px;
      right: 92px;
    }

    .cable {
      height: 1px;
      background: rgba(142, 240, 199, 0.34);
      transform-origin: left center;
    }

    .cable-one {
      top: 180px;
      right: 250px;
      width: 190px;
      transform: rotate(34deg);
    }

    .cable-two {
      top: 300px;
      right: 235px;
      width: 220px;
      transform: rotate(145deg);
    }

    .cable-three {
      top: 456px;
      right: 155px;
      width: 250px;
      transform: rotate(28deg);
    }

    .port {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 6px rgba(64, 211, 154, 0.08), 0 0 18px rgba(64, 211, 154, 0.45);
    }

    .port-one {
      top: 176px;
      right: 286px;
    }

    .port-two {
      top: 315px;
      right: 455px;
    }

    .port-three {
      top: 466px;
      right: 220px;
    }

    .page {
      width: min(980px, calc(100% - 32px));
      margin: 0 auto;
      padding: 56px 0 34px;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 180px;
      gap: 48px;
      align-items: center;
      padding-bottom: 42px;
      border-bottom: 1px solid var(--line);
    }

    .eyebrow {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1 {
      margin-bottom: 8px;
      font-size: clamp(3rem, 8vw, 5.8rem);
      line-height: 0.96;
    }

    h2 {
      margin-bottom: 14px;
      font-size: clamp(1.55rem, 3vw, 2.2rem);
      line-height: 1.1;
    }

    h3 {
      margin-bottom: 8px;
      font-size: 1rem;
    }

    .role {
      margin-bottom: 18px;
      color: var(--accent-soft);
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      font-weight: 800;
    }

    .summary {
      max-width: 720px;
      margin-bottom: 0;
      color: var(--muted);
      font-size: 1.08rem;
    }

    .portrait {
      width: 180px;
      height: 180px;
      border: 1px solid var(--line);
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 26px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 10px 15px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: var(--paper);
      color: var(--ink);
      font-weight: 800;
    }

    .button.primary {
      border-color: var(--accent);
      background: var(--accent);
      color: #06110d;
    }

    .button:hover,
    .button:focus-visible {
      border-color: var(--accent);
      opacity: 1;
      outline: none;
    }

    .section {
      padding: 38px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 28px;
      margin-bottom: 18px;
    }

    .section-heading p {
      max-width: 360px;
      margin-bottom: 14px;
      color: var(--muted);
    }

    .proof-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .proof-grid article,
    .project {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--paper);
    }

    .proof-grid article {
      padding: 18px;
    }

    .proof-grid p,
    .project p,
    .focus li,
    .footer p {
      color: var(--muted);
    }

    .proof-grid p,
    .project p {
      margin-bottom: 0;
    }

    .project-list {
      display: grid;
      gap: 12px;
    }

    .project {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 190px;
      gap: 18px;
      align-items: start;
      padding: 18px;
    }

    .project span {
      color: var(--accent-soft);
      font-size: 0.9rem;
      font-weight: 800;
      text-align: right;
    }

    .focus ul {
      display: grid;
      gap: 10px;
      padding-left: 20px;
      margin: 0;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding-top: 26px;
      font-weight: 800;
    }

    .footer p {
      margin: 0;
      font-weight: 700;
    }

    .footer a {
      color: var(--accent-soft);
    }

    @media (max-width: 760px) {
      :global(body) {
        background-size: 34px 34px, 34px 34px, auto, auto;
      }

      .network-bg {
        opacity: 0.28;
      }

      .network-bg::before {
        top: 18px;
        right: -120px;
        width: 300px;
        height: 360px;
      }

      .device {
        width: 70px;
        height: 32px;
      }

      .router {
        top: 40px;
        right: 18px;
      }

      .switch {
        top: 132px;
        right: -28px;
      }

      .server,
      .switch.alt,
      .cable-three,
      .port-three {
        display: none;
      }

      .cable-one {
        top: 86px;
        right: 48px;
        width: 110px;
      }

      .cable-two {
        top: 156px;
        right: -2px;
        width: 130px;
      }

      .port-one {
        top: 83px;
        right: 86px;
      }

      .port-two {
        top: 165px;
        right: 98px;
      }

      .page {
        width: min(100% - 24px, 980px);
        padding-top: 28px;
      }

      .hero {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .portrait {
        grid-row: 1;
        width: 132px;
        height: 132px;
      }

      .proof-grid,
      .project {
        grid-template-columns: 1fr;
      }

      .section-heading,
      .footer {
        display: grid;
      }

      .project span {
        text-align: left;
      }
    }
  </style>
</Base>
